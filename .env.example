# LM Studio API endpoint — use your Tailscale IP
LM_STUDIO_URL=http://100.x.x.x:1234

# The model name loaded in LM Studio (check LM Studio UI for exact name)
LM_STUDIO_MODEL=local-model

# Optional API key (leave blank if LM Studio has no auth configured)
LM_STUDIO_API_KEY=

# Bind Jarvis (default: 127.0.0.1:5757 — localhost only). Use 0.0.0.0 for Tailscale / LAN.
# JARVIS_HOST=0.0.0.0
# JARVIS_PORT=5757

# Optional: require this bearer token for /mobile API (set on phone once, stored in browser)
# MOBILE_DISPATCH_TOKEN=
